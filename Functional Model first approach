    "lstm_1_output = layers.LSTM(8, return_sequences=True, name='lstm_1')(embedding_layer_output)\n",
    "\n",
    "# LSTM layer - 2\n",
    "lstm_2_output = layers.LSTM(8, return_sequences=True, name='lstm_2')(lstm_1_output)\n",
    "\n",
    "# LSTM layer - 3\n",
    "lstm_3_output = layers.LSTM(8, return_sequences=False, name='lstm_3')(lstm_2_output)\n",
    "\n",
    "\n",
    "# Shared base\n",
    "shared_base = layers.Dense(64, activation='relu', name='shared_base')(lstm_3_output)\n",
    "\n",
    "\n",
    "# ---------------- sub model for multi-classification [rating]\n",
    "# rating layer 1\n",
    "rating_layer_1_output = layers.Dense(64, activation='relu', name='rating_sublayer_1')(shared_base)\n",
    "\n",
    "# rating layer 2\n",
    "rating_layer_2_output = layers.Dense(32, activation='relu', name='rating_sublayer_2')(rating_layer_1_output)\n",
    "\n",
    "# rating layer output\n",
    "rating_output = layers.Dense(5, activation='softmax', name='rating_output')(rating_layer_2_output)\n",
    "\n",
    "\n",
    "# --------------- sub model for binary-classification [recommend]\n",
    "# recommend layer 1\n",
