    "# Shared base\n",
    "shared_base = layers.Dense(64, activation='relu', name='shared_base')(lstm_3_output)\n",
    "\n",
    "\n",
    "# ---------------- sub model for multi-classification [rating]\n",
    "# rating layer 1\n",
    "rating_layer_1_output = layers.Dense(64, activation='relu', name='rating_sublayer_1')(shared_base)\n",
